+    _kgspCmp170hxPutU32(pSignatureVa, 0xf7e0, 0x00001fbdU);
+    _kgspCmp170hxPutU32(pSignatureVa, 0xf7f4, 0x00000ccbU);
+    _kgspCmp170hxPutU32(pSignatureVa, 0xf7f8, 0x00007f2fU);
+
+    return NV_OK;
+}
+
+static NV_STATUS
+_kgspCmp170hxArmPayloadSignature
+(
+    OBJGPU    *pGpu,
+    KernelGsp *pKernelGsp
+)
+{
+    MEMORY_DESCRIPTOR *pPayloadMemdesc = NULL;
+    MEMORY_DESCRIPTOR *pOldSignatureMemdesc;
+    NvU8 *pSignatureVa = NULL;
+    NvU64 flags = MEMDESC_FLAGS_NONE;
+    NV_STATUS status;
+
+    if ((pKernelGsp->pCmp170hxStockSignatureData == NULL) ||
+        (pKernelGsp->cmp170hxStockSignatureSize == 0) ||
+        (pKernelGsp->pSignatureMemdesc == NULL) ||
+        (pKernelGsp->pWprMeta == NULL) ||
+        (pKernelGsp->pWprMetaDescriptor == NULL))
+    {
+        return NV_ERR_INVALID_STATE;
+    }
+
+    if (pKernelGsp->bCmp170hxSignatureIsPayload)
+    {
+        return (memdescGetSize(pKernelGsp->pSignatureMemdesc) ==
+                CMP170HX_EXPERIMENTAL_SIGNATURE_SIZE) ?
+            NV_OK : NV_ERR_INVALID_STATE;
+    }
+
+    if (confComputeForceUnprotAlloc(pGpu))
+        flags |= MEMDESC_FLAGS_ALLOC_IN_UNPROTECTED_MEMORY;
+
+    status = memdescCreate(&pPayloadMemdesc, pGpu,
+                           CMP170HX_EXPERIMENTAL_SIGNATURE_SIZE, 256,
+                           NV_TRUE, ADDR_SYSMEM, NV_MEMORY_CACHED, flags);
+    if (status != NV_OK)
+        return status;
+
+    memdescTagAlloc(status,
+        NV_FB_ALLOC_RM_INTERNAL_OWNER_UNNAMED_TAG_16, pPayloadMemdesc);
+    if (status != NV_OK)
+        goto fail_create;
+
+    pSignatureVa = memdescMapInternal(pGpu, pPayloadMemdesc,
+                                      TRANSFER_FLAGS_NONE);
+    if (pSignatureVa == NULL)
+    {
+        status = NV_ERR_INSUFFICIENT_RESOURCES;
+        goto fail_alloc;
+    }
+
+    status = _kgspCmp170hxFillPayload(
+        pSignatureVa, memdescGetSize(pPayloadMemdesc),
+        _cmp170hxPlmWrites[0].addr, _cmp170hxPlmWrites[0].value);
+    memdescUnmapInternal(pGpu, pPayloadMemdesc, 0);
+    pSignatureVa = NULL;
+    if (status != NV_OK)
+        goto fail_alloc;
+
+    memdescFlushCpuCaches(pGpu, pPayloadMemdesc);
+    pOldSignatureMemdesc = pKernelGsp->pSignatureMemdesc;
+    pKernelGsp->pSignatureMemdesc = pPayloadMemdesc;
+    pKernelGsp->bCmp170hxSignatureIsPayload = NV_TRUE;
+    pKernelGsp->pWprMeta->sysmemAddrOfSignature =
+        memdescGetPhysAddr(pPayloadMemdesc, AT_GPU, 0);
+    pKernelGsp->pWprMeta->sizeOfSignature =
+        memdescGetSize(pPayloadMemdesc);
+    memdescFlushCpuCaches(pGpu, pKernelGsp->pWprMetaDescriptor);
+
+    memdescFree(pOldSignatureMemdesc);
+    memdescDestroy(pOldSignatureMemdesc);
+    return NV_OK;
+
+fail_alloc:
+    memdescFree(pPayloadMemdesc);
+fail_create:
+    memdescDestroy(pPayloadMemdesc);
+    return status;
+}
+
+static NV_STATUS
+_kgspCmp170hxRefillPayload
+(
+    OBJGPU   *pGpu,
+    KernelGsp *pKernelGsp,
+    NvU32     writeAddr,
+    NvU32     writeValue
+)
+{
+    NvU8 *pSignatureVa;
+    NV_STATUS status;
+
+    if ((pKernelGsp->pSignatureMemdesc == NULL) ||
+        (pKernelGsp->pWprMeta == NULL) ||
+        (pKernelGsp->pWprMetaDescriptor == NULL) ||
+        (memdescGetSize(pKernelGsp->pSignatureMemdesc) !=
+         CMP170HX_EXPERIMENTAL_SIGNATURE_SIZE))
+    {
+        return NV_ERR_INVALID_STATE;
+    }
+
+    pSignatureVa = memdescMapInternal(pGpu, pKernelGsp->pSignatureMemdesc,
+                                      TRANSFER_FLAGS_NONE);
+    if (pSignatureVa == NULL)
+        return NV_ERR_INSUFFICIENT_RESOURCES;
+
+    status = _kgspCmp170hxFillPayload(
+        pSignatureVa, memdescGetSize(pKernelGsp->pSignatureMemdesc),
+        writeAddr, writeValue);
+    memdescUnmapInternal(pGpu, pKernelGsp->pSignatureMemdesc, 0);
+    if (status != NV_OK)
+        return status;
+
+    memdescFlushCpuCaches(pGpu, pKernelGsp->pSignatureMemdesc);
+    pKernelGsp->pWprMeta->sysmemAddrOfSignature =
+        memdescGetPhysAddr(pKernelGsp->pSignatureMemdesc, AT_GPU, 0);
+    pKernelGsp->pWprMeta->sizeOfSignature =
+        memdescGetSize(pKernelGsp->pSignatureMemdesc);
+    memdescFlushCpuCaches(pGpu, pKernelGsp->pWprMetaDescriptor);
+
+    return NV_OK;
+}
+
+static NV_STATUS
+_kgspCmp170hxRebuildStockSignature
+(
+    OBJGPU    *pGpu,
+    KernelGsp *pKernelGsp
+)
+{
+    MEMORY_DESCRIPTOR *pNewSignatureMemdesc = NULL;
+    MEMORY_DESCRIPTOR *pOldSignatureMemdesc;
+    NvU8 *pSignatureVa = NULL;
+    NvU64 flags = MEMDESC_FLAGS_NONE;
+    NvU64 signatureSize;
+    NV_STATUS status;
+
+    if ((pKernelGsp->pCmp170hxStockSignatureData == NULL) ||
+        (pKernelGsp->cmp170hxStockSignatureSize == 0) ||
+        (pKernelGsp->pWprMeta == NULL) ||
+        (pKernelGsp->pWprMetaDescriptor == NULL))
+    {
+        return NV_ERR_INVALID_STATE;
+    }
+
+    signatureSize = NV_ALIGN_UP(pKernelGsp->cmp170hxStockSignatureSize, 256);
+    if (confComputeForceUnprotAlloc(pGpu))
+        flags |= MEMDESC_FLAGS_ALLOC_IN_UNPROTECTED_MEMORY;
+
+    status = memdescCreate(&pNewSignatureMemdesc, pGpu, signatureSize, 256,
+                           NV_TRUE, ADDR_SYSMEM, NV_MEMORY_CACHED, flags);
+    if (status != NV_OK)
+        return status;
+
+    memdescTagAlloc(status,
+        NV_FB_ALLOC_RM_INTERNAL_OWNER_UNNAMED_TAG_16, pNewSignatureMemdesc);
+    if (status != NV_OK)
+        goto fail_create;
+
+    pSignatureVa = memdescMapInternal(pGpu, pNewSignatureMemdesc,
+                                      TRANSFER_FLAGS_NONE);
+    if (pSignatureVa == NULL)
+    {
+        status = NV_ERR_INSUFFICIENT_RESOURCES;
+        goto fail_alloc;
+    }
+
+    portMemCopy(pSignatureVa, signatureSize,
+                pKernelGsp->pCmp170hxStockSignatureData,
+                pKernelGsp->cmp170hxStockSignatureSize);
+    memdescUnmapInternal(pGpu, pNewSignatureMemdesc, 0);
+    pSignatureVa = NULL;
+    memdescFlushCpuCaches(pGpu, pNewSignatureMemdesc);
+
+    pOldSignatureMemdesc = pKernelGsp->pSignatureMemdesc;
+    pKernelGsp->pSignatureMemdesc = pNewSignatureMemdesc;
+    pKernelGsp->bCmp170hxSignatureIsPayload = NV_FALSE;
+    pKernelGsp->pWprMeta->sysmemAddrOfSignature =
+        memdescGetPhysAddr(pNewSignatureMemdesc, AT_GPU, 0);
+    pKernelGsp->pWprMeta->sizeOfSignature =
+        memdescGetSize(pNewSignatureMemdesc);
+    memdescFlushCpuCaches(pGpu, pKernelGsp->pWprMetaDescriptor);
+
+    if (pOldSignatureMemdesc != NULL)
+    {
+        memdescFree(pOldSignatureMemdesc);
+        memdescDestroy(pOldSignatureMemdesc);
+    }
+    return NV_OK;
+
+fail_alloc:
+    memdescFree(pNewSignatureMemdesc);
+fail_create:
+    memdescDestroy(pNewSignatureMemdesc);
+    return status;
+}
