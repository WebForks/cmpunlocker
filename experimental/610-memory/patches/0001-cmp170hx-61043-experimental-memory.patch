+NV_STATUS
+memmgrCmp170hxLateExtendHighPmaRegion
+(
+    OBJGPU        *pGpu,
+    MemoryManager *pMemoryManager
+)
+{
+    const NvU64 stockFbBytes = 0x0000000200000000ULL;
+    const NvU64 targetFbBytes = 0x0000001000000000ULL;
+    Heap *pHeap;
+    PMA *pPma;
+    PMA_REGION_DESCRIPTOR pmaRegion = {0};
+    PMA_REGION_DESCRIPTOR *pFirstPmaRegionDesc = NULL;
+    PMA_REGION_DESCRIPTOR *pExistingPmaRegion;
+    FB_REGION_DESCRIPTOR *pCandidate = NULL;
+    NvU32 numPmaRegions = 0;
+    NvU64 pmaTotalBefore = 0;
+    NvU64 pmaTotalAfter = 0;
+    NvU64 expectedGrowth;
+    NvU32 candidateCount = 0;
+    NvU32 i;
+    NV_STATUS status;
+
+    if ((pGpu == NULL) || (pMemoryManager == NULL))
+        return NV_ERR_INVALID_ARGUMENT;
+
+    if ((pGpu->idInfo.PCIDeviceID >> 16) != 0x20C2)
+        return NV_ERR_NOT_SUPPORTED;
+
+    pHeap = pMemoryManager->pHeap;
+    if ((pHeap == NULL) || (pHeap->pPmaObject == NULL) ||
+        !memmgrIsPmaInitialized(pMemoryManager))
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-state status=0x%x\n",
+                  NV_ERR_INVALID_STATE);
+        return NV_ERR_INVALID_STATE;
+    }
+
+    pPma = pHeap->pPmaObject;
+    if (pPma->bNuma)
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-numa status=0x%x\n",
+                  NV_ERR_NOT_SUPPORTED);
+        return NV_ERR_NOT_SUPPORTED;
+    }
+
+    status = pmaGetRegionInfo(pPma, &numPmaRegions, &pFirstPmaRegionDesc);
+    if (status != NV_OK)
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-region-info status=0x%x\n",
+                  status);
+        return status;
+    }
+
+    if (numPmaRegions >= PMA_REGION_SIZE)
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-capacity regions=%u capacity=%u status=0x%x\n",
+                  numPmaRegions, PMA_REGION_SIZE,
+                  NV_ERR_INSUFFICIENT_RESOURCES);
+        return NV_ERR_INSUFFICIENT_RESOURCES;
+    }
+
+    if ((numPmaRegions > 0) &&
+        ((pFirstPmaRegionDesc == NULL) ||
+         (pFirstPmaRegionDesc != pPma->pRegDescriptors[0])))
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-descriptor-first status=0x%x\n",
+                  NV_ERR_INVALID_STATE);
+        return NV_ERR_INVALID_STATE;
+    }
+
+    if ((pMemoryManager->Ram.numFBRegions == 0) ||
+        (pMemoryManager->Ram.numFBRegions > MAX_FB_REGIONS))
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-fb-count regions=%u capacity=%u status=0x%x\n",
+                  pMemoryManager->Ram.numFBRegions, MAX_FB_REGIONS,
+                  NV_ERR_INVALID_DATA);
+        return NV_ERR_INVALID_DATA;
+    }
+
+    for (i = 0; i < pMemoryManager->Ram.numFBRegions; i++)
+    {
+        FB_REGION_DESCRIPTOR *pRegion = &pMemoryManager->Ram.fbRegion[i];
+
+        if (pRegion->bRsvdRegion && !pRegion->bInternalHeap &&
+            (pRegion->limit == (targetFbBytes - 1)) &&
+            (pRegion->base < stockFbBytes) &&
+            (pRegion->base <= pRegion->limit) &&
+            (pRegion->rsvdSize != 0))
+        {
+            pCandidate = pRegion;
+            candidateCount++;
+        }
+    }
+
+    if ((pCandidate == NULL) || (candidateCount != 1))
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-candidate candidates=%u status=0x%x\n",
+                  candidateCount, NV_ERR_INVALID_STATE);
+        return NV_ERR_INVALID_STATE;
+    }
+
+    pmaRegion.base = NV_MAX(pCandidate->base, stockFbBytes);
+    pmaRegion.limit = pCandidate->limit;
+    pmaRegion.performance = pCandidate->performance;
+    pmaRegion.bSupportCompressed = NV_FALSE;
+    pmaRegion.bSupportISO = pCandidate->bSupportISO;
+    pmaRegion.bProtected = pCandidate->bProtected;
+
+    if ((pmaRegion.base > pmaRegion.limit) ||
+        !NV_IS_ALIGNED(pmaRegion.base, PMA_GRANULARITY) ||
+        (pmaRegion.limit == NV_U64_MAX) ||
+        !NV_IS_ALIGNED(pmaRegion.limit + 1, PMA_GRANULARITY))
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-range base=0x%016llx limit=0x%016llx status=0x%x\n",
+                  pmaRegion.base, pmaRegion.limit,
+                  NV_ERR_INVALID_STATE);
+        return NV_ERR_INVALID_STATE;
+    }
+
+    expectedGrowth = pmaRegion.limit - pmaRegion.base + 1;
+
+    for (i = 0; i < numPmaRegions; i++)
+    {
+        pExistingPmaRegion = pPma->pRegDescriptors[i];
+        if ((pExistingPmaRegion == NULL) ||
+            (pExistingPmaRegion->base > pExistingPmaRegion->limit))
+        {
+            NV_PRINTF(LEVEL_ERROR,
+                      "cmpunlock610: fail stage=pma-descriptor index=%u status=0x%x\n",
+                      i, NV_ERR_INVALID_STATE);
+            return NV_ERR_INVALID_STATE;
+        }
+
+        // Inclusive interval intersection; no endpoint arithmetic can wrap.
+        if ((pmaRegion.base <= pExistingPmaRegion->limit) &&
+            (pExistingPmaRegion->base <= pmaRegion.limit))
+        {
+            NV_PRINTF(LEVEL_ERROR,
+                      "cmpunlock610: fail stage=pma-overlap index=%u existing-base=0x%016llx existing-limit=0x%016llx new-base=0x%016llx new-limit=0x%016llx status=0x%x\n",
+                      i, pExistingPmaRegion->base,
+                      pExistingPmaRegion->limit, pmaRegion.base,
+                      pmaRegion.limit, NV_ERR_INVALID_STATE);
+            return NV_ERR_INVALID_STATE;
+        }
+    }
+
+    if ((pCandidate->rsvdSize !=
+         (pCandidate->limit - pCandidate->base + 1)) ||
+        (pMemoryManager->Ram.reservedMemSize < expectedGrowth) ||
+        (pMemoryManager->Ram.fbUsableMemSize > stockFbBytes))
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-accounting reserved=0x%016llx usable=0x%016llx growth=0x%016llx status=0x%x\n",
+                  pMemoryManager->Ram.reservedMemSize,
+                  pMemoryManager->Ram.fbUsableMemSize, expectedGrowth,
+                  NV_ERR_INVALID_STATE);
+        return NV_ERR_INVALID_STATE;
+    }
+
+    if (pMemoryManager->Ram.numFBRegions >= MAX_FB_REGIONS)
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-fb-capacity regions=%u capacity=%u status=0x%x\n",
+                  pMemoryManager->Ram.numFBRegions, MAX_FB_REGIONS,
+                  NV_ERR_INSUFFICIENT_RESOURCES);
+        return NV_ERR_INSUFFICIENT_RESOURCES;
+    }
+
+    pmaGetTotalMemory(pPma, &pmaTotalBefore);
+    if (pmaTotalBefore > (NV_U64_MAX - expectedGrowth))
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-total-overflow before=0x%016llx growth=0x%016llx status=0x%x\n",
+                  pmaTotalBefore, expectedGrowth, NV_ERR_INVALID_STATE);
+        return NV_ERR_INVALID_STATE;
+    }
+
+    status = pmaRegisterRegion(pPma, numPmaRegions, NV_FALSE,
+                               &pmaRegion, 0, NULL);
+    if (status != NV_OK)
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-register status=0x%x\n",
+                  status);
+        return status;
+    }
+
+    pmaGetTotalMemory(pPma, &pmaTotalAfter);
+    if (!pmaIsPmaManaged(pPma, pmaRegion.base, pmaRegion.limit) ||
+        (pmaTotalAfter != (pmaTotalBefore + expectedGrowth)))
+    {
+        NV_PRINTF(LEVEL_ERROR,
+                  "cmpunlock610: fail stage=pma-verify base=0x%016llx limit=0x%016llx before=0x%016llx after=0x%016llx status=0x%x COLD_POWER_CYCLE_REQUIRED\n",
+                  pmaRegion.base, pmaRegion.limit, pmaTotalBefore,
+                  pmaTotalAfter, NV_ERR_INVALID_STATE);
+        return NV_ERR_INVALID_STATE;
+    }
+
+    {
+        FB_REGION_DESCRIPTOR publicRegion = *pCandidate;
+
+        publicRegion.base = pmaRegion.base;
+        publicRegion.limit = pCandidate->limit;
+        publicRegion.rsvdSize = 0;
+        publicRegion.bRsvdRegion = NV_FALSE;
+        publicRegion.bInternalHeap = NV_FALSE;
+        publicRegion.bSupportCompressed = NV_FALSE;
+
+        pCandidate->limit = stockFbBytes - 1;
+        pCandidate->rsvdSize = NV_MIN(pCandidate->rsvdSize,
+                                      pCandidate->limit - pCandidate->base + 1);
+
+        pMemoryManager->Ram.fbRegion[pMemoryManager->Ram.numFBRegions] = publicRegion;
+        pMemoryManager->Ram.numFBRegions++;
+    }
+
+    pMemoryManager->Ram.reservedMemSize -= expectedGrowth;
+    pMemoryManager->Ram.fbUsableMemSize += expectedGrowth;
+
+    memmgrRegenerateFbRegionPriority(pGpu, pMemoryManager);
