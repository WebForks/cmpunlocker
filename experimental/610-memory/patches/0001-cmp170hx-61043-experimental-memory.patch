@@ -2195,6 +2195,25 @@ NvBool RmInitAdapter(
         goto shutdown;
     }
 
+    //
+    // GSP static FB metadata has been consumed and RmInitNvDevice has created
+    // the PMA. Publish the validated high region before GPU visibility is
+    // reduced or any post-init consumer can allocate from FB.
+    //
+    if ((pGpu->idInfo.PCIDeviceID >> 16) == 0x20C2)
+    {
+        status.rmStatus = memmgrCmp170hxLateExtendHighPmaRegion(
+            pGpu, GPU_GET_MEMORY_MANAGER(pGpu));
+        if (status.rmStatus != NV_OK)
+        {
+            NV_PRINTF(LEVEL_ERROR,
+                      "cmpunlock610: fail stage=pma-init status=0x%x COLD_POWER_CYCLE_REQUIRED\n",
+                      status.rmStatus);
+            RM_SET_ERROR(status, RM_INIT_GPU_STATE_INIT_FAILED);
+            goto shutdown;
+        }
+    }
+
     //
     // Expanded GPU visibility in GPUMGR is no longer needed once the
     // GPU is initialized.
